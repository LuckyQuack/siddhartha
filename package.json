{
  "name": "siddartha",
  "version": "0.1.0",
  "description": "AI-powered reading companion — semantic memory across your reading life",
  "license": "Apache-2.0",
  "main": "electron/dist/electron/main.js",
  "scripts": {
    "dev": "next dev renderer -p 3000",
    "build": "next build renderer",
    "electron:dev": "concurrently --kill-others \"npm run dev\" \"tsc -p electron/tsconfig.json && wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "test": "jest",
    "tsc:electron": "tsc --project electron/tsconfig.json",
    "tsc:renderer": "tsc --project renderer/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@supabase/supabase-js": "^2.106.1",
    "@types/better-sqlite3": "^7.6.13",
    "ai": "^4.3.16",
    "better-sqlite3": "^12.11.1",
    "epubjs": "^0.3.93",
    "lucide-react": "^0.479.0",
    "next": "14.2.29",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-reader": "^2.0.15",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/electron": "^1.6.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.2.1",
    "electron-builder": "^25.1.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.11",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.siddartha.app",
    "productName": "Siddhartha",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/dist/**/*",
      "renderer/out/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "better-sqlite3@12.11.1": true
  }
}
